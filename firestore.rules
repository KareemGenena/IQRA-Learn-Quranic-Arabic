rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Letter-timing calibrations, one doc per word:
    //   calibrations/{lessonId}/words/{wordId}  ->  { b: [boundary seconds] }
    //
    // Anyone can read (learners need the timings). Only the admin —
    // authenticated via Firebase Auth with this exact email — can write,
    // and writes are shape-validated. Clients also re-validate on read
    // (monotonic, letter count) with words.json as the fallback.
    match /calibrations/{lessonId}/words/{wordId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.token.email == 'kintegracion@gmail.com'
        && request.resource.data.keys().hasOnly(['b'])
        && request.resource.data.b is list
        && request.resource.data.b.size() >= 2
        && request.resource.data.b.size() <= 12;
      allow delete: if request.auth != null
        && request.auth.token.email == 'kintegracion@gmail.com';
    }
  }
}
